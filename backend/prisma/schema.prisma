generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  CREW
}

enum ExpenseType {
  LABOR
  MATERIAL
  EQUIPMENT
  SUBCONTRACTOR
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
}

enum SovStatus {
  DRAFT
  SUBMITTED
  APPROVED
  LOCKED
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String
  role          UserRole  @default(CREW)
  assignedProjectIds String[] @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  timesheets    Timesheet[]
  auditLogs     AuditLog[]
  expenses      Expense[]
}

model Project {
  id                String        @id @default(uuid())
  name              String
  clientName        String
  originalContract  Float
  totalChangeOrders Float         @default(0)
  status            ProjectStatus @default(ACTIVE)
  estimatedCompletion Float       @default(0)
  startDate         DateTime?
  endDate           DateTime?
  description       String?
  designNumber      String?
  agencyNumber      String?
  agencyNumberType  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  budgetCategories  BudgetCategory[]
  expenses          Expense[]
  timesheets        Timesheet[]
  schedulesOfValue  ScheduleOfValue[]
  changeOrders      ChangeOrder[]
}

model BudgetCategory {
  id        String  @id @default(uuid())
  name      String
  budget    Float
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  expenses  Expense[]
}

model Expense {
  id              String        @id @default(uuid())
  amount          Float
  description     String
  expenseType     ExpenseType
  date            DateTime      @default(now())
  receiptUrl      String?
  categoryId      String?
  category        BudgetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id])
}

model Timesheet {
  id        String   @id @default(uuid())
  hours     Float
  rate      Float
  date      DateTime @default(now())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model ScheduleOfValue {
  id              String      @id @default(uuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  status          SovStatus   @default(DRAFT)
  approvedBy      String?
  approvedAt      DateTime?
  totalValue      Float       @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           SovItem[]
  changeOrders    ChangeOrder[]
}

model SovItem {
  id              String        @id @default(uuid())
  sovId           String
  sov             ScheduleOfValue @relation(fields: [sovId], references: [id], onDelete: Cascade)
  itemNumber      Int
  csiCode         String
  csiCodeTitle    String
  description     String
  value           Float         @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ChangeOrder {
  id              String      @id @default(uuid())
  projectId       String
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sovId           String?
  sov             ScheduleOfValue? @relation(fields: [sovId], references: [id])
  itemNumber      Int?
  csiCode         String?
  csiCodeTitle    String?
  description     String
  value           Float
  status          SovStatus   @default(DRAFT)
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OfficePayroll {
  id          String   @id @default(uuid())
  employeeName String
  position    String
  grossPay    Float
  taxes       Float
  insurance   Float
  netPay      Float
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())
}

model FixedAsset {
  id            String   @id @default(uuid())
  name          String
  category      String
  purchasePrice Float
  purchaseDate  DateTime @default(now())
  usefulLife    Int
  accumulatedDepreciation Float @default(0)
  currentValue  Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Payout {
  id          String   @id @default(uuid())
  type        String
  amount      Float
  recipient   String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  timestamp DateTime @default(now())
}
